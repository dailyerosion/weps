/**********************************
	   GFORTRAN32 COOK OPTIONS
 **********************************/
fc_name		=  [fc];

#include gfortran.cook

/*add the 32bit flag to fc and ld*/
fc_flags	+= "-m32";
ld_flags	+= "-m32";

function print "fc_flags are: " [fc_flags];
function print "ld_flags are: " [ld_flags];
