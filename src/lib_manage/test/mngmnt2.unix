# for testing purposes                                                 <
#                                                                      <
# Characters that begin a line in this file                            <
# represent one of the following:                                      <
#                                                                      <
#               '#' <- comment line                                    <
#               '+' <- continuation line                               <
#               '*' <- flag line                                       <
#               'P' <- process line                                    <
#               'D' <- date line                                       <
#                                                                      <
#       +---- subregion number                                         <
#       |   +---- number of years in each cycle                        <
#       |   |                                                          <
*START 001 003                                                         <
